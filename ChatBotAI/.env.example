# ChatBotAI Environment Configuration Example
# Copy this to .env and modify as needed

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-to-a-secure-random-string

# Database
DATABASE_URL=sqlite:///instance/chatbot.db

# Ollama AI Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=30

# AI Behavior
AI_AUTO_RESPONSE_ENABLED=true
AI_MEMORY_EXTRACTION_ENABLED=true
AI_RESPONSE_TONE=friendly_professional
MAX_CONVERSATION_HISTORY=10

# Gmail Integration
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
# Set this to your exact callback URL to avoid redirect_uri_mismatch errors
# Must match what's configured in Google Cloud Console > Authorized redirect URIs
# GMAIL_REDIRECT_URI=http://localhost/chatbot/gmail/callback

# WhatsApp Integration (future)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Airbnb Integration (future)
AIRBNB_API_URL=
AIRBNB_API_TOKEN=

# Booking.com Integration (future)
BOOKING_API_URL=
BOOKING_API_TOKEN=
